model LabScenario {
  id              String   @id @default(uuid()) @map("_id")
  slug            String   @unique
  title           String
  summary         String
  category        String
  difficulty      String
  estimatedMinutes Int
  tags            String[]
  type            String
  steps           Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  runs            LabRun[]

  @@map("lab_scenario")
}

model LabRun {
  id          String      @id @default(uuid()) @map("_id")
  scenarioId  String
  userId      String
  status      String      @default("in_progress")
  score       Int?
  answers     Json?
  startedAt   DateTime    @default(now())
  completedAt DateTime?
  scenario    LabScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  events      LabEvent[]

  @@index([userId])
  @@map("lab_run")
}

model LabEvent {
  id        String   @id @default(uuid()) @map("_id")
  runId     String
  type      String
  metadata  Json?
  createdAt DateTime @default(now())
  run       LabRun   @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, type])
  @@map("lab_event")
}
